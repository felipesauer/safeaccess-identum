{
    "source": {
        "directories": ["src"],
        "excludes": [
            "Contracts",
            "Exceptions"
        ]
    },
    "phpUnit": {
        "customPath": "vendor/bin/pest"
    },
    "testFramework": "phpunit",
    "minMsi": 85,
    "minCoveredMsi": 85,
    "threads": "max",
    "mutators": {
        "@default": true
    },
    "logs": {
        "summary": "build/infection/infection-summary.json"
    }
}
